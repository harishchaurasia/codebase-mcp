# codebase-mcp configuration
# Copy to .env and adjust as needed

# Path to the codebase to analyze (required for auto-load)
# CODEBASE_ROOT=/path/to/your/project

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log format: console or json
LOG_FORMAT=console

# Maximum file size to analyze (bytes). Files larger than this are skipped.
MAX_FILE_SIZE=1048576

# Transport mode: stdio or http
TRANSPORT=stdio

# HTTP mode settings (only used when TRANSPORT=http)
HTTP_HOST=127.0.0.1
HTTP_PORT=8000

# Memory cache directory. If unset, stores inside the analyzed repo at .codebase-mcp/
# MEMORY_DIR=~/.cache/codebase-mcp
